# --- Postgres (local dev: copy to `.env`; docker compose reads the same vars)
POSTGRES_USER=user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=social_blog
# Host port published from the `db` container (default 5433 if host :5432 is already taken).
POSTGRES_PUBLISH_PORT=5433
# Used when building DATABASE_URL for `make run` on the host (not used inside the `api` container).
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Optional: set a full async URL instead of POSTGRES_* (e.g. SQLite):
# DATABASE_URL=sqlite+aiosqlite:///./test.db
# DATABASE_URL=postgresql+asyncpg://user:change-me@localhost:5433/social_blog

IMAGEKIT_UPLOAD_FOLDER=/posts
IMAGEKIT_PRIVATE_KEY=<YOUR_IMAGEKIT_PRIVATE_KEY>
IMAGEKIT_PUBLIC_KEY=<YOUR_IMAGEKIT_PUBLIC_KEY>  # Optional, only needed for client-side URL building.

AWS_S3_BUCKET=<YOUR_S3_BUCKET_NAME>
AWS_REGION=<YOUR_S3_REGION>
S3_KEY_PREFIX=<YOUR_S3_KEY_PREFIX>  # e.g. "posts"

AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_ACCESS_KEY>

SECRET_KEY=<YOUR_SECRET_KEY>
